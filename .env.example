# Deployment settings. Copy to .env and edit:  cp .env.example .env
#
# The values below feed the Grafana dashboard build:
#   ./scripts/build-dashboard.sh
# That script renders grafana/dashboards/weather-forecast.json from the committed
# .template, injecting LATITUDE/LONGITUDE/PUBLIC_HOST/FORECAST_DAYS/TIMEZONE.
# Re-run it whenever you change any of those, then re-import the JSON into Grafana.
#
# nginx.conf itself reads NO env vars — the cache is location-agnostic (it caches
# whatever /v1/* URL Grafana requests). CACHE_TTL below is documentation only;
# edit nginx/nginx.conf to actually change it.

# --- Forecast location: Berlin, DE (example — set your own) ---
LATITUDE=52.52
LONGITUDE=13.405
# Injected into the dashboard query URLs by scripts/build-dashboard.sh

# --- Hourly variables requested from Open-Meteo (metric units are the API default) ---
# Documentation only: the variable list is FIXED in the dashboard template because
# each panel's JSONata query references specific fields. Changing this var alone
# would not change the dashboard (and mismatched fields would break panels).
HOURLY_VARS=temperature_2m,rain,snowfall,cloud_cover,wind_speed_10m,wind_direction_10m

# Injected into the dashboard query URLs by scripts/build-dashboard.sh:
FORECAST_DAYS=7
TIMEZONE=GMT

# --- Cache freshness window ---
# Edit `proxy_cache_valid 200 ...;` in nginx/nginx.conf to change this.
CACHE_TTL=30m

# --- Public hostname served by Nginx Proxy Manager ---
# Becomes the host in the dashboard query URLs (injected by build-dashboard.sh).
PUBLIC_HOST=weather.example.com
