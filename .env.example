# Reference values for this deployment.
#
# NOTE: nginx.conf does not read env vars at runtime, and the location/coordinates
# live in the Grafana query URL (the cache is location-agnostic — it caches whatever
# /v1/* URL is requested). This file documents the canonical values so they live in
# one place; edit the matching spots if you change them.

# --- Forecast location: Berlin, DE (example — set your own) ---
LATITUDE=52.52
LONGITUDE=13.405
# Used in: grafana/dashboards/weather-forecast.json and docs/grafana-setup.md (query URL)

# --- Hourly variables requested from Open-Meteo (metric units are the API default) ---
HOURLY_VARS=temperature_2m,rain,snowfall,cloud_cover,wind_speed_10m,wind_direction_10m
FORECAST_DAYS=7
TIMEZONE=GMT

# --- Cache freshness window ---
# Edit `proxy_cache_valid 200 ...;` in nginx/nginx.conf to change this.
CACHE_TTL=30m

# --- Public hostname served by Nginx Proxy Manager ---
PUBLIC_HOST=weather.example.com
